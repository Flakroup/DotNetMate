{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "GitVersionInfo": {
      "type": "object",
      "properties": {
        "Major": {
          "type": "integer",
          "format": "int32"
        },
        "Minor": {
          "type": "integer",
          "format": "int32"
        },
        "Patch": {
          "type": "integer",
          "format": "int32"
        },
        "PreReleaseTag": {
          "type": [
            "null",
            "string"
          ]
        },
        "PreReleaseTagWithDash": {
          "type": [
            "null",
            "string"
          ]
        },
        "PreReleaseLabel": {
          "type": [
            "null",
            "string"
          ]
        },
        "PreReleaseLabelWithDash": {
          "type": [
            "null",
            "string"
          ]
        },
        "PreReleaseNumber": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "WeightedPreReleaseNumber": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "BuildMetaData": {
          "type": [
            "null",
            "string"
          ]
        },
        "FullBuildMetaData": {
          "type": [
            "null",
            "string"
          ]
        },
        "MajorMinorPatch": {
          "type": [
            "null",
            "string"
          ]
        },
        "SemVer": {
          "type": [
            "null",
            "string"
          ]
        },
        "AssemblySemVer": {
          "type": [
            "null",
            "string"
          ]
        },
        "AssemblySemFileVer": {
          "type": [
            "null",
            "string"
          ]
        },
        "FullSemVer": {
          "type": [
            "null",
            "string"
          ]
        },
        "InformationalVersion": {
          "type": [
            "null",
            "string"
          ]
        },
        "BranchName": {
          "type": [
            "null",
            "string"
          ]
        },
        "EscapedBranchName": {
          "type": [
            "null",
            "string"
          ]
        },
        "Sha": {
          "type": [
            "null",
            "string"
          ]
        },
        "ShortSha": {
          "type": [
            "null",
            "string"
          ]
        },
        "NuGetVersionV2": {
          "type": [
            "null",
            "string"
          ]
        },
        "NuGetVersion": {
          "type": [
            "null",
            "string"
          ]
        },
        "NuGetPreReleaseTag": {
          "type": [
            "null",
            "string"
          ]
        },
        "NuGetPreReleaseTagV2": {
          "type": [
            "null",
            "string"
          ]
        },
        "VersionSourceSha": {
          "type": [
            "null",
            "string"
          ]
        },
        "CommitsSinceVersionSource": {
          "type": "integer",
          "format": "int32"
        },
        "CommitDate": {
          "type": [
            "null",
            "string"
          ]
        },
        "UncommittedChanges": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "Benchmark",
        "CI",
        "Clean",
        "Compile",
        "Full",
        "Info",
        "InstallLocal",
        "Pack",
        "Publish",
        "Restore",
        "Tag",
        "Test"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "Configuration": {
          "type": "string",
          "description": "Configuration to build - Default is 'Debug' (local) or 'Release' (server)",
          "enum": [
            "Debug",
            "Release"
          ]
        },
        "GitVersionInfo": {
          "description": "GitVersion output (auto-resolved)",
          "$ref": "#/definitions/GitVersionInfo"
        },
        "NuGetApiKey": {
          "type": "string",
          "description": "NuGet API key for pushing packages",
          "default": "Secrets must be entered via 'nuke :secrets [profile]'"
        },
        "NuGetSource": {
          "type": "string",
          "description": "NuGet source URL for pushing packages"
        },
        "Solution": {
          "type": "string",
          "description": "Path to a solution file that is automatically loaded"
        },
        "TagPrefix": {
          "type": "string",
          "description": "Git tag prefix (default: v)"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
